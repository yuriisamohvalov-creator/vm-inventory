# PostgreSQL
POSTGRES_DB=vminventory
POSTGRES_USER=vminventory
POSTGRES_PASSWORD=vminventory_secret

# Backend
PORT=8000
# Для Docker healthcheck нужен 127.0.0.1; в K8s добавьте ingress host.
# ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# Auth (local users)
# If auth_user table is empty, this account is created automatically on startup.
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=P@ssw0rD
AUTH_BOOTSTRAP_ROLE=admin
AUTH_TOKEN_TTL_MINUTES=480

# LDAP (optional, leave empty for no-auth)
# When set, backend can use LDAP provider (implementation-specific)
LDAP_URI=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=secret
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_GROUPS_BASE=ou=groups,dc=example,dc=com
# Optional JSON map for future LDAP group -> local role sync.
# Example: {"administrator":["cn=vm-admins,ou=groups,dc=example,dc=com"],"analyst":["cn=vm-analysts,ou=groups,dc=example,dc=com"]}
LDAP_ROLE_GROUP_MAP=
