# PostgreSQL
POSTGRES_DB=vminventory
POSTGRES_USER=vminventory
POSTGRES_PASSWORD=vminventory_secret

# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# LDAP (optional, leave empty for no-auth)
# When set, backend can use LDAP provider (implementation-specific)
LDAP_URI=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=secret
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_GROUPS_BASE=ou=groups,dc=example,dc=com
